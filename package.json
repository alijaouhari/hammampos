{
  "name": "hammampos-desktop",
  "version": "2.0.0",
  "description": "HammamPOS Desktop - Professional Point-of-Sale system for Moroccan hammams",
  "main": "src/main/main-working.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:installer": "npm run build:win && build-installer.bat",
    "dist": "npm run build:installer",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "pos",
    "hammam",
    "point-of-sale",
    "morocco",
    "thermal-printer",
    "professional",
    "premium"
  ],
  "author": "HammamPOS Solutions",
  "license": "Proprietary",
  "homepage": "https://hammampos.com",
  "build": {
    "appId": "com.hammampos.desktop",
    "productName": "HammamPOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HammamPOS"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "sql.js": "^1.13.0"
  }
}
